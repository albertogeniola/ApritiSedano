<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Dark). -->
    <style name="Theme.ApritiSedano" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/sedano_primary</item>
        <item name="colorPrimaryVariant">@color/sedano_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/sedano_accent</item>
        <item name="colorSecondaryVariant">@color/sedano_accent</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Backgrounds -->
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>